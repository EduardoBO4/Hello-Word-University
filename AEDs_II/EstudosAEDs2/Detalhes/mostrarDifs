// Nó básico para a Árvore Binária
class No {
    public int elemento;
    public No esq, dir;
    public No(int elemento) {
        this.elemento = elemento;
        this.esq = this.dir = null;
    }
}

// Classe Árvore Binária
class Arvore {
    public No raiz; // Guardamos a raiz aqui dentro

    // O "mostrar" sem parâmetro: É a ponte para o mundo externo.
    // Você não precisa lembrar se é pré, pós ou central, quem usa a árvore só chama .mostrar()
    public void mostrar() {
        System.out.print("[Árvore Binária - Caminhamento Central]: ");
        mostrarCentral(raiz); // Repassa o trabalho para o método real passando a raiz
        System.out.println();
    }

    // O "mostrar" com parâmetro: Esse sim faz o trabalho duro e recursivo
    private void mostrarCentral(No i) {
        if (i != null) {
            mostrarCentral(i.esq);
            System.out.print(i.elemento + " ");
            mostrarCentral(i.dir);
        }
    }
}

// Classe Lista Encadeada (Simples, apenas para demonstração)
class Lista {
    public void mostrar() {
        // Listas são sequenciais, então o mostrar delas usa um "while" ou um print direto
        System.out.println("[Lista Encadeada]: Elemento_A -> Elemento_B -> NULL");
    }
}

// Classe T3: A tabela Hash mista (Vetor + Árvore de Reserva)
class HashT3 {
    public int[] tabela = {30, 40, -1}; // Vetor do T3 (-1 significa posição vazia)
    public Arvore arvoreReserva = new Arvore(); // Árvore na reserva de T3

    public void mostrar() {
        System.out.print("[Tabela Hash T3]: ");
        for (int i = 0; i < tabela.length; i++) {
            if (tabela[i] != -1) System.out.print(tabela[i] + " ");
        }
        System.out.println();
        
        // O T3 também tem que mostrar a árvore dele! Ele terceiriza para a classe Árvore:
        System.out.print("  └─> ");
        arvoreReserva.mostrar(); 
    }
}

