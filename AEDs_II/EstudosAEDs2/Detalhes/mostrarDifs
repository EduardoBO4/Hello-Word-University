// 2. A REVOLUCIONÁRIA: CLASSE DOIDONA
// =========================================================================
class Doidona {
    // Para podermos testar o seu método "aberto/inseguro" no main,
    // deixei essas variáveis como 'public'. No mundo real elas seriam 'private'.
    public int[] t1 = {10, 20, -1}; // Vetor principal da Doidona
    public HashT3 t3 = new HashT3();
    public Lista lista = new Lista();
    public Arvore arvore = new Arvore();

    // Construtor apenas para colocar alguns dados de teste dentro delas
    public Doidona() {
        arvore.raiz = new No(88);
        arvore.raiz.esq = new No(55);
        arvore.raiz.dir = new No(99);

        t3.arvoreReserva.raiz = new No(7);
    }

    // A FORMA ENCAPSULADA: O mostrar que você achou limpo, mas não gostou
    public void mostrar() {
        System.out.println("\n=== EXECUÇÃO: FORMA ENCAPSULADA (doidona.mostrar()) ===");
        
        // 1. Ela mesma imprime o seu vetor T1
        System.out.print("[Vetor T1 Principal]: ");
        for (int i = 0; i < t1.length; i++) {
            if (t1[i] != -1) System.out.print(t1[i] + " ");
        }
        System.out.println();

        // 2. Ela terceiriza o resto, chamando o 'mostrar' específico de cada uma!
        t3.mostrar();
        lista.mostrar();
        arvore.mostrar();
    }
}

